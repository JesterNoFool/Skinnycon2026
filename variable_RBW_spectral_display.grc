- name: fft_vxx_0
  id: fft_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    fft_size: N
    forward: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    nthreads: '1'
    shift: 'True'
    type: complex
    window: '[1/Nd,]*N'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 600.0]
    rotation: 0
    state: enabled
- name: import_0
