options:
  parameters:
    author: ''
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: ''
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: basic_spectral_display
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Basic Spectral Display
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: N
  id: variable_qtgui_label
  parameters:
    comment: ''
    formatter: None
    gui_hint: 2,10,1,10
    label: 'FFT Size: '
    type: real
    value: 2**13
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 24.0]
    rotation: 0
    state: enabled
- name: Nd
  id: variable
  parameters:
    comment: 'Number of data samples

      based on the desired RBW.'
    value: int(samp_rate*nenbw/rbw)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [768, 176.0]
    rotation: 0
    state: enabled
- name: cpg
  id: variable
  parameters:
    comment: 'Coherent power gain

      -----------------------------

      Value: (np.sum(w)/Nd)**2'
    value: (np.sum(w)/Nd)**2
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [840, 24.0]
    rotation: 0
    state: enabled
- name: ipg
  id: variable
  parameters:
    comment: 'Incoherent power gain

      -------------------------------

      Value: np.sum(np.power(w,2))/Nd'
    value: np.sum(np.power(w,2))/Nd
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [616, 24.0]
    rotation: 0
    state: enabled
- name: nenbw
  id: variable
  parameters:
    comment: 'This is the NENBW of the

      desired window. Due to

      how this flowgraph works,

      it cannot be calculated

      within the flowgraph;

      therefore, the user must

      manually enter the value.'
    value: '2.0044'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1024, 32.0]
    rotation: 0
    state: enabled
- name: rbw
  id: variable
  parameters:
    comment: 'Desired RBW

      in Hz.'
    value: '2000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [616, 184.0]
    rotation: 0
    state: enabled
- name: rf_gain
  id: variable_qtgui_chooser
  parameters:
    comment: ''
    gui_hint: 0,0,1,20
    label: 'RF Gain (dB): '
    label0: ''
    label1: ''
    label2: ''
    label3: ''
    label4: ''
    labels: '["-1.0", "1.5", "4.0", "6.5", "9.0", "11.5", "14.0", "16.5", "19.0",
      "21.5", "24.0", "29.0", "34.0", "42.0"]'
    num_opts: '0'
    option0: '0'
    option1: '1'
    option2: '2'
    option3: '3'
    option4: '4'
    options: '[-1.0, 1.5, 4.0, 6.5, 9.0, 11.5, 14.0, 16.5, 19.0, 21.5, 24.0, 29.0,
      34.0, 42.0]'
    orient: Qt.QVBoxLayout
    type: real
    value: '16.5'
    widget: combo_box
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [112, 168.0]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: 2.4e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [176, 24.0]
    rotation: 0
    state: enabled
- name: w
  id: variable
  parameters:
    comment: 'Value: window.<window_name>(Nd)

      where "window_name" can be:

      rectangular

      hann

      hamming

      blackman

      blackmanharris

      flattop

      nuttall

      nuttall_cfd

      kaiser*


      *Kaiser also requires a beta value, so

      its use would be something like

      "window.kaiser(Nd,4)", where the

      beta value is 4.'
    value: window.blackmanharris(Nd)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1216, 32.0]
    rotation: 0
    state: enabled
- name: blocks_complex_to_mag_squared_0
  id: blocks_complex_to_mag_squared
  parameters:
    affinity: ''
    alias: ''
    comment: 'Calculate magnitude

      for each frequency

      point.'
    maxoutbuf: '0'
    minoutbuf: '0'
    vlen: N
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [512, 632.0]
    rotation: 0
    state: enabled
- name: blocks_moving_average_xx_0
  id: blocks_moving_average_xx
  parameters:
    affinity: ''
    alias: ''
    comment: 'Calculate average for each

      frequency bin.'
    length: '20'
    max_iter: '4000'
    maxoutbuf: '0'
    minoutbuf: '0'
    scale: 1/20
    type: float
    vlen: N
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [696, 608.0]
    rotation: 0
    state: enabled
- name: blocks_multiply_const_vxx_0
  id: blocks_multiply_const_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: Window the data
    const: w
    maxoutbuf: '0'
    minoutbuf: '0'
    type: complex
    vlen: Nd
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [568, 408.0]
    rotation: 0
    state: enabled
- name: blocks_nlog10_ff_0
  id: blocks_nlog10_ff
  parameters:
    affinity: ''
    alias: ''
    comment: 'Calculate logarithm

      (dB) for each frequency

      point and normalize

      for CPG/IPG (user

      defined).'
    k: -10*np.log10(cpg)
    maxoutbuf: '0'
    minoutbuf: '0'
    n: '10'
    vlen: N
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [912, 616.0]
    rotation: 0
    state: enabled
- name: blocks_null_source_0
  id: blocks_null_source
  parameters:
    affinity: ''
    alias: ''
    bus_structure_source: '[[0,],]'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_outputs: '1'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [792, 488.0]
    rotation: 0
    state: enabled
- name: blocks_repeat_0
  id: blocks_repeat
  parameters:
    affinity: ''
    alias: ''
    comment: 'This is to deal with a

      bug in the Vector Sink

      block which causes it

      to drop data randomly.'
    interp: '2'
    maxoutbuf: '0'
    minoutbuf: '0'
    type: float
    vlen: N
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1096, 624.0]
    rotation: 0
    state: enabled
- name: blocks_stream_mux_0
  id: blocks_stream_mux
  parameters:
    affinity: ''
    alias: ''
    comment: Zeropad to a power-of-2.
    lengths: (Nd,(N-Nd))
    maxoutbuf: '0'
    minoutbuf: '0'
    num_inputs: '2'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [968, 424.0]
    rotation: 0
    state: enabled
- name: blocks_stream_to_vector_0
  id: blocks_stream_to_vector
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: Nd
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [384, 424.0]
    rotation: 0
    state: enabled
- name: blocks_stream_to_vector_1
  id: blocks_stream_to_vector
  parameters:
    affinity: ''
    alias: ''
    comment: Create time record for FFT.
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: N
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1184, 440.0]
    rotation: 0
    state: enabled
- name: blocks_vector_to_stream_0
